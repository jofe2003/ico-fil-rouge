def extraire_route(route_id, customers_all, vehicles_all, depots_all,
                   constraints_all, distances_all):
    """Filtre les donnees pour une route_id donnee."""
    rid = float(route_id)
    def filtre(rows): return [r for r in rows if r.get('ROUTE_ID','') == rid]

    customers   = filtre(customers_all)
    vehicles    = filtre(vehicles_all)
    depot_rows  = filtre(depots_all)
    constraints = filtre(constraints_all)
    distances   = filtre(distances_all)

    depot = {
        'code'    : str(depot_rows[0]['DEPOT_CODE']),
        'lat'     : float(depot_rows[0]['DEPOT_LATITUDE']),
        'lon'     : float(depot_rows[0]['DEPOT_LONGITUDE']),
        'tw_from' : float(depot_rows[0]['DEPOT_AVAILABLE_TIME_FROM_MIN']) if depot_rows[0]['DEPOT_AVAILABLE_TIME_FROM_MIN'] != '' else 0.0,
        'tw_to'   : float(depot_rows[0]['DEPOT_AVAILABLE_TIME_TO_MIN'])   if depot_rows[0]['DEPOT_AVAILABLE_TIME_TO_MIN']   != '' else 1440.0,
    }

    clients = []
    for c in customers:
        clients.append({
            'code'       : str(c['CUSTOMER_CODE']),
            'lat'        : float(c['CUSTOMER_LATITUDE']),
            'lon'        : float(c['CUSTOMER_LONGITUDE']),
            'poids_kg'   : float(c['TOTAL_WEIGHT_KG'])   if c['TOTAL_WEIGHT_KG']   != '' else 0.0,
            'volume_m3'  : float(c['TOTAL_VOLUME_M3'])   if c['TOTAL_VOLUME_M3']   != '' else 0.0,
            'tw_from'    : float(c['CUSTOMER_TIME_WINDOW_FROM_MIN']) if c['CUSTOMER_TIME_WINDOW_FROM_MIN'] != '' else 0.0,
            'tw_to'      : float(c['CUSTOMER_TIME_WINDOW_TO_MIN'])   if c['CUSTOMER_TIME_WINDOW_TO_MIN']   != '' else 1440.0,
            'service_min': float(c['CUSTOMER_DELIVERY_SERVICE_TIME_MIN']) if c['CUSTOMER_DELIVERY_SERVICE_TIME_MIN'] != '' else 0.0,
        })

    # Vehicules : on charge aussi les couts reels du zip
    veh_list = []
    for v in vehicles:
        veh_list.append({
            'code'        : str(v['VEHICLE_CODE']),
            'cap_kg'      : float(v['VEHICLE_TOTAL_WEIGHT_KG'])          if v['VEHICLE_TOTAL_WEIGHT_KG']          != '' else 9999.0,
            'cap_m3'      : float(v['VEHICLE_TOTAL_VOLUME_M3'])          if v['VEHICLE_TOTAL_VOLUME_M3']          != '' else 9999.0,
            # Cout variable (€/km) et cout fixe (€) issus du fichier 3
            'cout_var_km' : float(v['VEHICLE_VARIABLE_COST_KM'])         if v['VEHICLE_VARIABLE_COST_KM']         != '' else 1.0,
            'cout_fixe'   : float(v['VEHICLE_FIXED_COST_KM'])            if v['VEHICLE_FIXED_COST_KM']            != '' else 0.0,
            'dispo_from'  : float(v['VEHICLE_AVAILABLE_TIME_FROM_MIN'])   if v['VEHICLE_AVAILABLE_TIME_FROM_MIN']   != '' else 0.0,
            'dispo_to'    : float(v['VEHICLE_AVAILABLE_TIME_TO_MIN'])     if v['VEHICLE_AVAILABLE_TIME_TO_MIN']     != '' else 1440.0,
        })

    dist_reel  = {}
    temps_reel = {}
    for d in distances:
        code      = str(d['CUSTOMER_CODE'])
        direction = str(d['DIRECTION'])
        dist_km   = float(d['DISTANCE_KM'])       if d['DISTANCE_KM']       != '' else 0.0
        temps_min = float(d['TIME_DISTANCE_MIN'])  if d['TIME_DISTANCE_MIN']  != '' else 0.0
        dist_reel [(code, direction)] = dist_km
        temps_reel[(code, direction)] = temps_min

    vitesses = []
    for (code, direction), dist in dist_reel.items():
        t = temps_reel.get((code, direction), 0)
        if t > 0 and dist > 0:
            vitesses.append(dist / (t/60))
    vitesse_moy = sum(vitesses)/len(vitesses) if vitesses else 50.0

    sdvrp = defaultdict(set)
    for c in constraints:
        sdvrp[str(c['SDVRP_CONSTRAINT_CUSTOMER_CODE'])].add(
              str(c['SDVRP_CONSTRAINT_VEHICLE_CODE']))

    return depot, clients, veh_list, dist_reel, temps_reel, vitesse_moy, sdvrp


