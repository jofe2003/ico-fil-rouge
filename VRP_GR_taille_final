# BLOC 6 : SOLUTION INITIALE ALEATOIRE
# ==============================================================

def solution_initiale(n_clients, veh_list, clients, sdvrp, seed):
    """
    Construit une solution initiale aleatoire (seed fixe = reproductible).
    Respecte : capacite poids + contraintes SDVRP.
    """
    random.seed(seed)
    n_veh   = len(veh_list)
    ordre   = list(range(1, n_clients+1))
    random.shuffle(ordre)
    routes  = [[0] for _ in range(n_veh)]
    charges = [0.0] * n_veh
    non_places = []

    for client_idx in ordre:
        place     = False
        veh_ordre = list(range(n_veh))
        random.shuffle(veh_ordre)
        for v in veh_ordre:
            poids_client = clients[client_idx-1]['poids_kg']
            veh_code     = veh_list[v]['code']
            if (charges[v] + poids_client <= veh_list[v]['cap_kg'] and
                    sdvrp_ok(client_idx, veh_code, clients, sdvrp)):
                routes[v].append(client_idx)
                charges[v] += poids_client
                place = True
                break
        if not place:
            non_places.append(client_idx)

    for v in range(n_veh):
        routes[v].append(0)

    if non_places:
        print("  ATTENTION : {} clients non places !".format(len(non_places)))

    return routes


# ==============================================================
# BLOC 7 : VOISINAGE PAR RELOCATION
# ==============================================================

def generer_voisins(routes, clients, veh_list, sdvrp, temps_mat):
    """
    Genere tous les mouvements de relocation valides.
    Un mouvement (client, v_src, pos_src, v_dst, pos_dst) est valide si :
      1. Capacite poids respectee dans la route destination
      2. Contrainte SDVRP respectee
      3. Fenetres de temps respectees dans la route destination
    """
    voisins = []
    for v_src in range(len(routes)):
        for pos_src, client_idx in enumerate(routes[v_src]):
            if client_idx == 0: continue
            poids_client = clients[client_idx-1]['poids_kg']
            for v_dst in range(len(routes)):
                if v_dst == v_src: continue
                veh_code_dst = veh_list[v_dst]['code']
                cap_dst      = veh_list[v_dst]['cap_kg']
                heure_depart = veh_list[v_dst]['dispo_from']

                charge_dst = sum(clients[c-1]['poids_kg'] for c in routes[v_dst] if c != 0)
                if charge_dst + poids_client > cap_dst: continue
                if not sdvrp_ok(client_idx, veh_code_dst, clients, sdvrp): continue

                for pos_dst in range(1, len(routes[v_dst])):
                    route_test = (routes[v_dst][:pos_dst]
                                  + [client_idx]
                                  + routes[v_dst][pos_dst:])
                    if fenetres_temps_ok(route_test, clients, temps_mat, heure_depart):
                        voisins.append((client_idx, v_src, pos_src, v_dst, pos_dst))
    return voisins


def appliquer_mouvement(routes, mouvement):
    client_idx, v_src, pos_src, v_dst, pos_dst = mouvement
    r = [route[:] for route in routes]
    r[v_src].pop(pos_src)
    r[v_dst].insert(pos_dst, client_idx)
    return r


def est_tabou(mouvement, liste_tabou):
    client_idx, v_src, _, v_dst, _ = mouvement
    return (client_idx, v_src, v_dst) in liste_tabou


def mouvement_inverse(mouvement):
    client_idx, v_src, _, v_dst, _ = mouvement
    return (client_idx, v_dst, v_src)


# ==============================================================
# BLOC 8 : ALGORITHME TABOU
# ==============================================================

def tabou_vrp(routes_init, dist_mat, temps_mat, clients, veh_list, sdvrp):
    """
    Algorithme Tabou pour le VRP avec fenetres de temps et contraintes SDVRP.

    A chaque iteration :
      1. Generer tous les voisins valides (relocation inter-routes)
      2. Choisir le meilleur voisin non tabou
         (ou tabou si critere d'aspiration : cout < meilleur global)
      3. Appliquer le mouvement et mettre a jour la liste tabou
      4. Mettre a jour la meilleure solution si amelioration

    Arret : NB_MAX_ITER atteint, ou aucun voisin valide.
    """
    routes    = [r[:] for r in routes_init]
    cout      = calculer_cout(routes, dist_mat, veh_list)
    routes_s  = [r[:] for r in routes]
    cout_s    = cout
    tabou     = []
    nbiter    = 0
    meil_iter = 0

    while nbiter < NB_MAX_ITER:
        nbiter += 1
        voisins = generer_voisins(routes, clients, veh_list, sdvrp, temps_mat)
        if not voisins:
            print("  Aucun voisin valide -> arret anticipe a l'iter {}".format(nbiter))
            break

        best_mv = None; best_cout = float('inf'); best_routes = None
        for mv in voisins:
            new_routes = appliquer_mouvement(routes, mv)
            new_cout   = calculer_cout(new_routes, dist_mat, veh_list)
            is_tab     = est_tabou(mv, tabou)
            aspiration = new_cout < cout_s   # critere d'aspiration
            if (not is_tab) or aspiration:
                if new_cout < best_cout:
                    best_cout = new_cout; best_mv = mv; best_routes = new_routes

        if best_mv is None:
            continue

        routes = best_routes; cout = best_cout
        tabou.append(mouvement_inverse(best_mv))
        if len(tabou) > TAILLE_TABOU: tabou.pop(0)

        if cout < cout_s:
            cout_s    = cout
            routes_s  = [r[:] for r in routes]
            meil_iter = nbiter

    return routes_s, cout_s, meil_iter


# ==============================================================
# BLOC 9 : AFFICHAGE DETAIL D'UNE SOLUTION
# ==============================================================

def afficher_solution(routes, clients, veh_list, temps_mat, titre):
    SEP = "=" * 65
    print("\n" + SEP)
    print(titre)
    print(SEP)
    for v, route in enumerate(routes):
        n_cli     = sum(1 for c in route if c != 0)
        charge_kg = sum(clients[c-1]['poids_kg']  for c in route if c != 0)
        charge_m3 = sum(clients[c-1]['volume_m3'] for c in route if c != 0)
        cap_kg    = veh_list[v]['cap_kg']
        cap_m3    = veh_list[v]['cap_m3']
        hdep      = veh_list[v]['dispo_from']
        statut    = "OK" if fenetres_temps_ok(route, clients, temps_mat, hdep) else "VIOLATION TW"
        codes     = ['Depot' if c == 0 else clients[c-1]['code'] for c in route]
        print("  V{} [{}] ({} clients) poids={:.1f}/{:.0f}kg vol={:.2f}/{:.2f}m3 [{}]".format(
            v+1, veh_list[v]['code'], n_cli,
            charge_kg, cap_kg, charge_m3, cap_m3, statut))
        print("    " + " -> ".join(codes))
    print()


# ==============================================================
# BLOC 10 : TRAITEMENT COMPLET D'UNE ROUTE
# ==============================================================

def traiter_route(route_id, customers_all, vehicles_all, depots_all,
                  constraints_all, distances_all, verbose=False):
    """
    Pipeline complet pour une route :
      1. Extraire les donnees du zip
      2. Construire les matrices distances/temps
      3. Generer la solution initiale aleatoire (seed fixe)
      4. Lancer l'algorithme Tabou
      5. Retourner les resultats
    """
    depot, clients, veh_list, dist_reel, temps_reel, vitesse_moy, sdvrp = \
        extraire_route(route_id, customers_all, vehicles_all, depots_all,
                       constraints_all, distances_all)

    n_clients = len(clients)
    n_veh     = len(veh_list)

    dist_mat, temps_mat = construire_matrices(
        depot, clients, dist_reel, temps_reel, vitesse_moy)

    routes_init = solution_initiale(n_clients, veh_list, clients, sdvrp, SEED)
    cout_init   = calculer_cout(routes_init, dist_mat, veh_list)
    dist_init   = calculer_distance_totale(routes_init, dist_mat)

    if verbose:
        afficher_solution(routes_init, clients, veh_list, temps_mat, "SOLUTION INITIALE")

    temps_debut = time.time()
    routes_fin, cout_final, meil_iter = tabou_vrp(
        routes_init, dist_mat, temps_mat, clients, veh_list, sdvrp)
    temps_exec = time.time() - temps_debut

    dist_fin   = calculer_distance_totale(routes_fin, dist_mat)
    amelio     = (cout_init - cout_final) / cout_init * 100 if cout_init > 0 else 0.0
    violations = sum(
        1 for v, route in enumerate(routes_fin)
        if not fenetres_temps_ok(route, clients, temps_mat, veh_list[v]['dispo_from'])
    )

    if verbose:
        afficher_solution(routes_fin, clients, veh_list, temps_mat, "SOLUTION FINALE")

    return {
        'route_id'   : route_id,
        'n_clients'  : n_clients,
        'n_veh'      : n_veh,
        'cout_init'  : cout_init,    # euros : cout_fixe + cout_var_km * dist
        'cout_final' : cout_final,   # euros
        'dist_init'  : dist_init,    # km    : distance totale (info)
        'dist_fin'   : dist_fin,     # km
        'amelio'     : amelio,       # %
        'meil_iter'  : meil_iter,
        'temps_exec' : temps_exec,   # secondes (algo Tabou uniquement)
        'violations' : violations,   # nb routes avec violation TW
    }


