        print(f"  V{v+1} [{veh_list[v]['code']}] ({n_cli} clients) "
              f"charge={charge_kg:.1f}/{cap_kg:.0f}kg "
              f"vol={charge_m3:.2f}/{cap_m3:.2f}m3 [{statut}]")
        print(f"    {' -> '.join(codes)}")
    print()


