def extraire_route(route_id, customers_all, vehicles_all, depots_all,
                   constraints_all, distances_all):
    """Filtre les donnees pour une route_id donnee."""
    rid = float(route_id)
    def filtre(rows): return [r for r in rows if r.get('ROUTE_ID','') == rid]

    customers   = filtre(customers_all)
    vehicles    = filtre(vehicles_all)
    depot_rows  = filtre(depots_all)
    constraints = filtre(constraints_all)
    distances   = filtre(distances_all)

    def fval(d, key, default):
        v = d.get(key, '')
        return float(v) if v != '' else default

    depot = {
        'code'    : str(depot_rows[0]['DEPOT_CODE']),
        'lat'     : fval(depot_rows[0], 'DEPOT_LATITUDE',                0.0),
        'lon'     : fval(depot_rows[0], 'DEPOT_LONGITUDE',               0.0),
        'tw_from' : fval(depot_rows[0], 'DEPOT_AVAILABLE_TIME_FROM_MIN', 0.0),
        'tw_to'   : fval(depot_rows[0], 'DEPOT_AVAILABLE_TIME_TO_MIN', 1440.0),
    }

    clients = []
    for c in customers:
        clients.append({
            'code'       : str(c['CUSTOMER_CODE']),
            'lat'        : fval(c, 'CUSTOMER_LATITUDE',                   0.0),
            'lon'        : fval(c, 'CUSTOMER_LONGITUDE',                  0.0),
            'poids_kg'   : fval(c, 'TOTAL_WEIGHT_KG',                     0.0),
            'volume_m3'  : fval(c, 'TOTAL_VOLUME_M3',                     0.0),
            'tw_from'    : fval(c, 'CUSTOMER_TIME_WINDOW_FROM_MIN',        0.0),
            'tw_to'      : fval(c, 'CUSTOMER_TIME_WINDOW_TO_MIN',       1440.0),
            'service_min': fval(c, 'CUSTOMER_DELIVERY_SERVICE_TIME_MIN',   0.0),
        })

    # Vehicules : couts reels issus du fichier 3_detail_table_vehicles.xls
    veh_list = []
    for v in vehicles:
        veh_list.append({
            'code'       : str(v['VEHICLE_CODE']),
            'cap_kg'     : fval(v, 'VEHICLE_TOTAL_WEIGHT_KG',          9999.0),
            'cap_m3'     : fval(v, 'VEHICLE_TOTAL_VOLUME_M3',          9999.0),
            # cout variable en euros/km (VEHICLE_VARIABLE_COST_KM)
            'cout_var_km': fval(v, 'VEHICLE_VARIABLE_COST_KM',            1.0),
            # cout fixe en euros par vehicule utilise (VEHICLE_FIXED_COST_KM)
            'cout_fixe'  : fval(v, 'VEHICLE_FIXED_COST_KM',               0.0),
            'dispo_from' : fval(v, 'VEHICLE_AVAILABLE_TIME_FROM_MIN',      0.0),
            'dispo_to'   : fval(v, 'VEHICLE_AVAILABLE_TIME_TO_MIN',    1440.0),
        })

    dist_reel  = {}
    temps_reel = {}
    for d in distances:
        code      = str(d['CUSTOMER_CODE'])
        direction = str(d['DIRECTION'])
        dist_reel [(code, direction)] = float(d['DISTANCE_KM'])      if d['DISTANCE_KM']      != '' else 0.0
        temps_reel[(code, direction)] = float(d['TIME_DISTANCE_MIN']) if d['TIME_DISTANCE_MIN'] != '' else 0.0

    vitesses = []
    for (code, direction), dist in dist_reel.items():
        t = temps_reel.get((code, direction), 0)
        if t > 0 and dist > 0:
            vitesses.append(dist / (t / 60.0))
    vitesse_moy = sum(vitesses) / len(vitesses) if vitesses else 50.0

    sdvrp = defaultdict(set)
    for c in constraints:
        sdvrp[str(c['SDVRP_CONSTRAINT_CUSTOMER_CODE'])].add(
              str(c['SDVRP_CONSTRAINT_VEHICLE_CODE']))

    return depot, clients, veh_list, dist_reel, temps_reel, vitesse_moy, sdvrp


# ==============================================================
# BLOC 3 : MATRICES DISTANCES ET TEMPS
# ==============================================================

R_TERRE = 6371.0

def haversine(lat1, lon1, lat2, lon2):
    dlat = math.radians(lat2 - lat1)
    dlon = math.radians(lon2 - lon1)
    a = (math.sin(dlat/2)**2 +
         math.cos(math.radians(lat1)) * math.cos(math.radians(lat2)) * math.sin(dlon/2)**2)
    return 2 * R_TERRE * math.asin(math.sqrt(a))


def construire_matrices(depot, clients, dist_reel, temps_reel, vitesse_moy):
    """
    Indice 0 = depot, 1..N = clients.
    dist_mat[i][j]  : distance en km   de i vers j.
    temps_mat[i][j] : temps en minutes de i vers j.
    depot <-> client : distances reelles du fichier 6.
    client <-> client : Haversine + vitesse moyenne observee.
    """
    n = len(clients)
    dist_mat  = [[0.0]*(n+1) for _ in range(n+1)]
    temps_mat = [[0.0]*(n+1) for _ in range(n+1)]

    for i, ci in enumerate(clients, 1):
        d_dc = dist_reel.get((ci['code'], 'DEPOT->CUSTOMER'), None)
        t_dc = temps_reel.get((ci['code'], 'DEPOT->CUSTOMER'), None)
        if d_dc is None: d_dc = haversine(depot['lat'], depot['lon'], ci['lat'], ci['lon'])
        if t_dc is None: t_dc = d_dc / vitesse_moy * 60.0

        d_cd = dist_reel.get((ci['code'], 'CUSTOMER->DEPOT'), None)
        t_cd = temps_reel.get((ci['code'], 'CUSTOMER->DEPOT'), None)
        if d_cd is None: d_cd = haversine(ci['lat'], ci['lon'], depot['lat'], depot['lon'])
        if t_cd is None: t_cd = d_cd / vitesse_moy * 60.0

        dist_mat[0][i]  = d_dc;  temps_mat[0][i]  = t_dc
        dist_mat[i][0]  = d_cd;  temps_mat[i][0]  = t_cd

        for j, cj in enumerate(clients, 1):
            if i != j:
                d = haversine(ci['lat'], ci['lon'], cj['lat'], cj['lon'])
                dist_mat[i][j]  = d
                temps_mat[i][j] = d / vitesse_moy * 60.0

    return dist_mat, temps_mat


# ==============================================================
# BLOC 4 : FONCTION DE COUT
#
# Formule du cours :
#   f(x) = omega * K(x) + sum_(i,j) in E  c_ij
#
# Implementation :
#   omega * K(x)     = sum_k cout_fixe_k       (cout fixe par vehicule utilise)
#   sum_(i,j) c_ij   = sum_k cout_var_km_k * dist_k  (cout variable en euros/km)
#
# Source des couts : fichier 3_detail_table_vehicles.xls
# ==============================================================

def calculer_cout(routes, dist_mat, veh_list):
    """
    Retourne le cout total en euros :
      f(x) = sum_k [ cout_fixe_k + cout_var_km_k * distance_k ]
    Seuls les vehicules avec au moins un client sont comptes.
    """
    cout_total = 0.0
    for k, route in enumerate(routes):
        if not any(c != 0 for c in route):
            continue
        dist_route = sum(dist_mat[route[p]][route[p+1]] for p in range(len(route)-1))
        cout_total += veh_list[k]['cout_fixe'] + veh_list[k]['cout_var_km'] * dist_route
    return cout_total


def calculer_distance_totale(routes, dist_mat):
    """Retourne la distance totale en km (sans les couts vehicules)."""
    return sum(dist_mat[route[p]][route[p+1]]
               for route in routes for p in range(len(route)-1))


# ==============================================================
# BLOC 5 : VERIFICATION DES CONTRAINTES
# ==============================================================

def sdvrp_ok(client_idx, veh_code, clients, sdvrp):
    """Retourne True si le vehicule est autorise a servir ce client."""
    if client_idx == 0: return True
    return veh_code not in sdvrp.get(clients[client_idx-1]['code'], set())


def fenetres_temps_ok(route, clients, temps_mat, heure_depart):
    """
    Verifie que la route respecte les fenetres de temps [ai, bi].
    Attente autorisee si on arrive avant ai.
    Retourne False si on arrive apres bi pour un client.
    """
    t = heure_depart
    for k in range(len(route)-1):
        i = route[k]; j = route[k+1]
        t += temps_mat[i][j]
        if j == 0: break
        client = clients[j-1]
        if t > client['tw_to']:
            return False
        t = max(t, client['tw_from'])
        t += client['service_min']
    return True


