# BLOC 3 : MATRICES DISTANCES ET TEMPS
# ══════════════════════════════════════════════════════════════════════

R_TERRE = 6371.0

def haversine(lat1, lon1, lat2, lon2):
    dlat = math.radians(lat2 - lat1)
    dlon = math.radians(lon2 - lon1)
    a = (math.sin(dlat/2)**2 +
         math.cos(math.radians(lat1)) * math.cos(math.radians(lat2)) * math.sin(dlon/2)**2)
    return 2 * R_TERRE * math.asin(math.sqrt(a))


def construire_matrices(depot, clients, dist_reel, temps_reel, vitesse_moy):
    n = len(clients)
    dist_mat  = [[0.0]*(n+1) for _ in range(n+1)]
    temps_mat = [[0.0]*(n+1) for _ in range(n+1)]

    for i, ci in enumerate(clients, 1):
        # depot -> client i : distances reelles du fichier 6
        d_dc = dist_reel.get((ci['code'], 'DEPOT->CUSTOMER'), None)
        t_dc = temps_reel.get((ci['code'], 'DEPOT->CUSTOMER'), None)
        if d_dc is None: d_dc = haversine(depot['lat'], depot['lon'], ci['lat'], ci['lon'])
        if t_dc is None: t_dc = d_dc / vitesse_moy * 60

        # client i -> depot : distances reelles du fichier 6
        d_cd = dist_reel.get((ci['code'], 'CUSTOMER->DEPOT'), None)
        t_cd = temps_reel.get((ci['code'], 'CUSTOMER->DEPOT'), None)
        if d_cd is None: d_cd = haversine(ci['lat'], ci['lon'], depot['lat'], depot['lon'])
        if t_cd is None: t_cd = d_cd / vitesse_moy * 60

        dist_mat[0][i]  = d_dc;  temps_mat[0][i]  = t_dc
        dist_mat[i][0]  = d_cd;  temps_mat[i][0]  = t_cd

        # client i <-> client j : Haversine + vitesse moyenne observee
        for j, cj in enumerate(clients, 1):
            if i != j:
                d = haversine(ci['lat'], ci['lon'], cj['lat'], cj['lon'])
                dist_mat[i][j]  = d
                temps_mat[i][j] = d / vitesse_moy * 60

    return dist_mat, temps_mat


# ══════════════════════════════════════════════════════════════════════
# BLOC 4 : FONCTION DE COUT  f(x) = sum_k [ cout_fixe_k + cout_var_k * dist_k ]
#
# Correspond a la formule du cours :
#   f(x) = omega * K(x) + sum_(i,j) in E  c_ij
#
# Ici : omega * K(x) = sum_k cout_fixe_k  (coût fixe par véhicule utilisé)
#       sum c_ij      = sum_k cout_var_k * dist_k  (coût variable par km)
# ══════════════════════════════════════════════════════════════════════

def calculer_cout(routes, dist_mat, veh_list):
    """
    Calcule le cout total de la solution en euros :
      f(x) = sum sur chaque vehicule k de :
               cout_fixe_k  (si la route n'est pas vide)
             + cout_var_km_k * distance_totale_k

    Les distances depot<->client viennent du fichier 6 (reelles PTV).
    Les distances client<->client viennent de Haversine + vitesse moyenne.
    """
    cout_total = 0.0
    for k, route in enumerate(routes):
        # Ignorer les routes vides (vehicule non utilise)
        clients_route = [c for c in route if c != 0]
        if not clients_route:
            continue

        cout_var_km = veh_list[k]['cout_var_km']
        cout_fixe   = veh_list[k]['cout_fixe']

        # Distance totale de la route
        dist_route = 0.0
        for idx in range(len(route)-1):
            dist_route += dist_mat[route[idx]][route[idx+1]]

        # Cout de cette route = fixe + variable * distance
        cout_total += cout_fixe + cout_var_km * dist_route

    return cout_total


def calculer_distance_totale(routes, dist_mat):
    """
    Calcule la distance totale en km (sans les couts vehicules).
    Utile pour le bilan et la comparaison.
    """
    dist = 0.0
    for route in routes:
        for k in range(len(route)-1):
            dist += dist_mat[route[k]][route[k+1]]
    return dist


